rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isAdminEmail() { 
      return isSignedIn() && 
        'email' in request.auth.token && 
        request.auth.token.email != null &&
        (
          request.auth.token.email.lower() == 'ayushgaikwad7050@gmail.com' ||
          request.auth.token.email.lower() == 'ayushgaikwad705o@gmail.com' || 
          request.auth.token.email.lower() == 'mrunmayeebodhe118@gmail.com' ||
          request.auth.token.email.lower() == 'webcreator500@gmail.com' ||
          request.auth.token.email.lower() == 'forenclue@gmail.com'
        ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt'])
        && data.uid is string && data.uid.size() <= 128
        && (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 256));
    }

    function isValidDoubt(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'authorId', 'authorName', 'createdAt'])
        && data.title is string
        && data.content is string;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'content', 'authorId', 'authorName', 'createdAt'])
        && data.content is string;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'targetId', 'targetType', 'reporterId', 'createdAt'])
        && data.targetType in ['doubt', 'comment']
        && data.reporterId == request.auth.uid
        && data.createdAt is timestamp;
    }

    function isValidCourseStat(data) {
      return data.keys().hasAll(['students', 'updatedAt'])
        && data.students is number;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'price'])
        && data.id is number
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.price is number;
    }

    function isValidEbook(data) {
      return data.keys().hasAll(['title', 'pdfUrl'])
        && data.title is string && data.title.size() <= 200
        && data.pdfUrl is string && data.pdfUrl.size() <= 2000;
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['courseId', 'content', 'createdAt'])
        && data.courseId is number
        && data.content is string && data.content.size() <= 5000
        && data.createdAt is timestamp;
    }

    function isValidWebsiteText(data) {
      return data.keys().hasAll(['text'])
        && data.text is string && data.text.size() <= 5000;
    }

    // --- Cases ---
    match /cases/{caseId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // --- Courses ---
    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if isAdminEmail() && isValidCourse(incoming());
      allow delete: if isAdminEmail();
    }

    // --- Ebooks ---
    match /ebooks/{ebookId} {
      allow read: if true;
      allow create, update: if isAdminEmail() && isValidEbook(incoming());
      allow delete: if isAdminEmail();
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update: if isAdminEmail() && isValidAnnouncement(incoming());
      allow delete: if isAdminEmail();
    }

    // --- Website Texts ---
    match /websiteTexts/{textId} {
      allow read: if true;
      allow create, update: if isAdminEmail() && isValidWebsiteText(incoming());
      allow delete: if isAdminEmail();
    }

    // --- User Profiles ---
    match /users/{userId} {
      // Allow public get so profile details can be seen in community links
      allow get: if true;
      allow list: if isSignedIn(); 
      
      allow write: if isOwner(userId) && existing() == null;
      allow update: if isOwner(userId) && existing().uid == incoming().uid;
    }

    // --- Reports ---
    match /reports/{reportId} {
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && incoming().id == reportId;
      // Reports are typically only readable by admins, but for now we'll keep it private
      allow read: if false; 
    }

    // --- Course Stats ---
    match /courseStats/{courseId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/courseStats/$(courseId)) ? 
          isValidCourseStat(incoming()) : 
          incoming().diff(existing()).affectedKeys().hasOnly(['students', 'updatedAt'])
      );
    }
    
    // --- Course Overrides (Admin dynamically editable courses) ---
    match /courseOverrides/{courseId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    // --- Lecture QnA ---
    match /lectureQna/{qnaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && existing().authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && existing().authorId == request.auth.uid;
      }
    }

    // --- Community Doubts ---
    match /doubts/{doubtId} {
      // Allow anyone (even unauthenticated) to view doubts
      allow get: if true;
      allow list: if true; 

      allow create: if isSignedIn() && isValidId(doubtId) && isValidDoubt(incoming()) && incoming().id == doubtId && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && incoming().authorId == existing().authorId && (
        // Action: Like (any signed-in user)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) ||
        // Action: Resolve (owner only)
        (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['resolved', 'updatedAt'])) ||
        // Action: Edit (owner only)
        (existing().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'imageUrl', 'updatedAt']))
      );
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdminEmail());

      // Nested Comments
      match /comments/{commentId} {
        allow get: if true;
        allow list: if true;

        allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming()) && incoming().id == commentId;
        allow update, delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdminEmail());
      }
    }
  }
}
